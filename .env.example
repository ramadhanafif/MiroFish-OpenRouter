# =============================================================
# MiroFish-Offline Configuration
# =============================================================
# LLM + embeddings via any OpenAI-compatible API (OpenRouter by default).
# Copy this file to .env and adjust values for your setup.
# =============================================================

# ===== LLM Configuration (OpenAI-compatible format) =====
# Get your key at https://openrouter.ai/keys
LLM_API_KEY=sk-or-v1-REPLACE_ME
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_NAME=deepseek/deepseek-v4-flash
# Alternatives:
# LLM_MODEL_NAME=openai/gpt-4o-mini
# LLM_MODEL_NAME=google/gemini-2.5-flash
# LLM_MODEL_NAME=qwen/qwen2.5-72b-instruct

# ===== Neo4j Configuration =====
# For Docker: use service name "neo4j" instead of "localhost"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

# ===== Embedding Configuration (OpenAI-compatible format) =====
# EMBEDDING_API_KEY falls back to LLM_API_KEY if unset.
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small
# Vector size of the chosen embedding model. text-embedding-3-small = 1536.
# Changing this drops and recreates the Neo4j vector indexes on next startup.
EMBEDDING_DIMENSIONS=1536

# ===== OASIS / CAMEL-AI Configuration =====
# CAMEL-AI reads OPENAI_API_KEY and OPENAI_API_BASE_URL.
# Points to the same OpenRouter endpoint.
OPENAI_API_KEY=sk-or-v1-REPLACE_ME
OPENAI_API_BASE_URL=https://openrouter.ai/api/v1

# ===== Push Notifications (optional, via ntfy) =====
# Set NTFY_TOPIC to enable. Subscribe to the same topic in the ntfy app
# (https://ntfy.sh) to get a push when a step finishes or fails.
# NTFY_TOKEN is only needed for protected topics or self-hosted servers.
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=
